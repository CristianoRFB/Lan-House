@model ErrorViewModel
@{
    ViewData["Title"] = "Erro";
}

<section class="page-header">
    <div>
        <p class="eyebrow">Falha tratada</p>
        <h2>O painel encontrou um erro inesperado</h2>
        <p class="text-secondary">O servidor continuou respondendo, mas esta tela precisou ser interrompida para evitar uma falha em cascata.</p>
    </div>
    <div class="button-row">
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-accent">Tentar novamente</a>
        <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-light">Voltar ao login</a>
    </div>
</section>

<section class="panel">
    <h3>O que fazer agora</h3>
    <ul class="tutorial-list">
        <li>Tente abrir o painel novamente.</li>
        <li>Se o erro persistir, feche e abra o ADMIN para reiniciar o servidor local.</li>
        <li>Se estiver em manutencao ou primeiro uso, confira se o banco local foi criado corretamente.</li>
    </ul>

    @if (Model.ShowRequestId)
    {
        <p class="text-secondary mb-0">
            Codigo da requisicao: <code>@Model.RequestId</code>
        </p>
    }
</section>
