@model DashboardPageViewModel
@{
    ViewData["Title"] = "Painel";
    var maxDay = Math.Max(1m, Model.Dashboard.UsageByDay.Any() ? Model.Dashboard.UsageByDay.Max(point => point.Value) : 1m);
    var maxMachine = Math.Max(1m, Model.Dashboard.UsageByMachine.Any() ? Model.Dashboard.UsageByMachine.Max(point => point.Value) : 1m);
}

<section class="page-header">
    <div>
        <p class="eyebrow">Visao geral</p>
        <h2>@Model.Dashboard.CafeName</h2>
        <p class="text-secondary">Servidor central, clientes por maquina, sessoes de PC e console, historico financeiro e auditoria em portugues.</p>
    </div>
    <div class="button-row">
        <a asp-controller="Tutorial" asp-action="Index" class="btn btn-outline-light">Abrir tutorial completo</a>
    </div>
</section>

<section class="callout-card">
    <div>
        <p class="eyebrow mb-2">Primeiro uso</p>
        <h3 class="mb-2">Use o tutorial completo para configurar e operar o sistema sem perder passos.</h3>
        <p class="text-secondary mb-0">O guia dentro do painel explica a ordem recomendada, como informar o IP do ADMIN nos clientes e o que fazer em cada menu do sistema.</p>
    </div>
    <a asp-controller="Tutorial" asp-action="Index" class="btn btn-accent">Ver tutorial</a>
</section>

<section class="metric-grid">
    <article class="metric-card"><span>Maquinas online</span><strong>@Model.Dashboard.OnlineMachines</strong></article>
    <article class="metric-card"><span>Maquinas em uso</span><strong>@Model.Dashboard.ActiveMachines</strong></article>
    <article class="metric-card"><span>Sessoes ativas</span><strong>@Model.Dashboard.ActiveSessions</strong></article>
    <article class="metric-card"><span>Solicitacoes</span><strong>@Model.Dashboard.PendingRequests</strong></article>
    <article class="metric-card"><span>Anotacoes pendentes</span><strong>R$ @Model.Dashboard.PendingAnnotations.ToString("N2")</strong></article>
    <article class="metric-card"><span>Promessas</span><strong>R$ @Model.Dashboard.PromisedPayments.ToString("N2")</strong></article>
</section>

<section class="two-column">
    <article class="panel">
        <h3>Uso por dia</h3>
        <div class="bars">
            @foreach (var point in Model.Dashboard.UsageByDay)
            {
                var height = (int)Math.Round((point.Value / maxDay) * 100m);
                <div class="bar-column">
                    <div class="bar" style="height:@Math.Max(height, 8)%"></div>
                    <span>@point.Label</span>
                </div>
            }
        </div>
    </article>
    <article class="panel">
        <h3>Maquinas mais usadas</h3>
        @foreach (var point in Model.Dashboard.UsageByMachine)
        {
            var width = (int)Math.Round((point.Value / maxMachine) * 100m);
            <div class="usage-row">
                <span>@point.Label</span>
                <div class="usage-track"><div class="usage-fill" style="width:@Math.Max(width, 10)%"></div></div>
                <strong>@point.Value</strong>
            </div>
        }
    </article>
</section>

<section class="two-column">
    <article class="panel">
        <h3>Solicitacoes pendentes</h3>
        @if (!Model.Dashboard.Requests.Any())
        {
            <p class="text-secondary">Nenhuma solicitacao aguardando aprovacao.</p>
        }
        else
        {
            @foreach (var request in Model.Dashboard.Requests)
            {
                <div class="request-card">
                    <div>
                        <strong>@request.Type</strong>
                        <p>@request.MachineName · @request.RequestedDisplayName (@request.RequestedLogin)</p>
                        <small>@request.RequestedAtUtc.ToLocalTime().ToString("dd/MM HH:mm")</small>
                    </div>
                    <div class="action-stack">
                        <form asp-action="ResolveRequest" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="RequestId" value="@request.Id" />
                            <input type="hidden" name="Approve" value="true" />
                            <input type="hidden" name="ResponseMessage" value="Solicitacao aprovada pelo administrador." />
                            <button class="btn btn-success btn-sm">Aprovar</button>
                        </form>
                        <form asp-action="ResolveRequest" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="RequestId" value="@request.Id" />
                            <input type="hidden" name="Approve" value="false" />
                            <input type="hidden" name="ResponseMessage" value="Solicitacao rejeitada pelo administrador." />
                            <button class="btn btn-outline-warning btn-sm">Rejeitar</button>
                        </form>
                    </div>
                </div>
            }
        }
    </article>
    <article class="panel">
        <h3>Logs recentes</h3>
        <div class="log-list">
            @foreach (var log in Model.Dashboard.Logs)
            {
                <div class="log-item">
                    <strong>@log.Category / @log.EventType</strong>
                    <p>@log.Description</p>
                    <small>@log.CreatedAtUtc.ToLocalTime().ToString("dd/MM HH:mm") @if (!string.IsNullOrWhiteSpace(log.IpAddress)) { <text>· @log.IpAddress</text> }</small>
                </div>
            }
        </div>
    </article>
</section>
