<Window x:Class="Adrenalina.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adrenalina Client"
        Width="1280"
        Height="820"
        WindowStartupLocation="CenterScreen"
        Background="#0B1020"
        Foreground="#EEF2FF">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#09111E" Offset="0" />
                <GradientStop Color="#131D33" Offset="0.52" />
                <GradientStop Color="#0D1424" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="MachineTitleText" FontSize="28" FontWeight="Bold" Text="ADRENALINA CLIENT" />
                    <TextBlock x:Name="SessionStatusText" Margin="0,8,0,0" Foreground="#B3C2D9" Text="Carregando estado local..." />
                    <TextBlock x:Name="ConnectivityText" Margin="0,6,0,0" Foreground="#7FD9C7" Text="Conexao aguardando a primeira sincronizacao." />
                </StackPanel>

                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button x:Name="SettingsButton"
                            Margin="0,0,10,0"
                            Padding="14,10"
                            Content="Configuracoes"
                            Click="SettingsButton_Click" />
                    <Button x:Name="TutorialButton"
                            Padding="14,10"
                            Content="Tutorial"
                            Click="TutorialButton_Click" />
                </WrapPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,24,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="SessionCard"
                        Padding="22"
                        Margin="0,0,14,0"
                        Background="#141D32"
                        BorderBrush="#26314D"
                        BorderThickness="1"
                        CornerRadius="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Sessao atual" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock x:Name="CurrentUserText" Grid.Row="1" Margin="0,16,0,0" FontSize="18" Text="Usuario: aguardando login" />
                        <TextBlock x:Name="ProfileText" Grid.Row="2" Margin="0,6,0,0" Foreground="#B3C2D9" Text="Perfil: bloqueado" />

                        <WrapPanel Grid.Row="3" Margin="0,20,0,0">
                            <Border Padding="16" Margin="0,0,12,0" CornerRadius="18" Background="#1D2944">
                                <StackPanel>
                                    <TextBlock Text="Tempo" Foreground="#B3C2D9" />
                                    <TextBlock x:Name="RemainingTimeText" FontSize="24" FontWeight="Bold" Text="--" />
                                </StackPanel>
                            </Border>
                            <Border Padding="16" Margin="0,0,12,0" CornerRadius="18" Background="#1D2944">
                                <StackPanel>
                                    <TextBlock Text="Saldo" Foreground="#B3C2D9" />
                                    <TextBlock x:Name="BalanceText" FontSize="24" FontWeight="Bold" Text="R$ 0,00" />
                                </StackPanel>
                            </Border>
                            <Border Padding="16" CornerRadius="18" Background="#1D2944">
                                <StackPanel>
                                    <TextBlock Text="Anotado" Foreground="#B3C2D9" />
                                    <TextBlock x:Name="AnnotationText" FontSize="24" FontWeight="Bold" Text="R$ 0,00" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <Border Grid.Row="4"
                                Margin="0,24,0,0"
                                Padding="18"
                                CornerRadius="18"
                                Background="#1A2338"
                                BorderBrush="#2B3652"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Observacoes da conta" FontWeight="SemiBold" />
                                <TextBlock x:Name="NotesText" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#B3C2D9" Text="Sem observacoes." />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="LoginCard"
                        Grid.Column="1"
                        Padding="22"
                        Background="#141D32"
                        BorderBrush="#26314D"
                        BorderThickness="1"
                        CornerRadius="24">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Entrar na maquina" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Margin="0,8,0,18"
                                       Foreground="#B3C2D9"
                                       Text="Preencha usuario e PIN para liberar a maquina. As outras opcoes ficam logo abaixo."
                                       TextWrapping="Wrap" />

                            <TextBlock Text="Usuario" />
                            <TextBox x:Name="LoginTextBox" Margin="0,6,0,12" Padding="10" />

                            <TextBlock Text="PIN de 4 digitos" />
                            <PasswordBox x:Name="PinBox" Margin="0,6,0,18" Padding="10" />

                            <Button x:Name="LoginButton" Content="Entrar" Margin="0,0,0,14" Padding="14,10" Click="LoginButton_Click" />

                            <Expander Header="Outras opcoes" IsExpanded="False">
                                <StackPanel Margin="0,14,0,0">
                                    <TextBlock Foreground="#B3C2D9"
                                               Text="Use essas acoes apenas quando precisar de ajuda do atendimento."
                                               TextWrapping="Wrap" />

                                    <TextBlock Margin="0,14,0,0" Text="Nome para cadastro" />
                                    <TextBox x:Name="DisplayNameTextBox" Margin="0,6,0,12" Padding="10" />

                                    <TextBlock Text="Mensagem para o atendimento" />
                                    <TextBox x:Name="MessageTextBox"
                                             Margin="0,6,0,12"
                                             Height="88"
                                             Padding="10"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True" />

                                    <Button Content="Solicitar cadastro" Margin="0,0,0,10" Padding="14,10" Click="RequestRegistration_Click" />
                                    <Button Content="Pedir mais tempo" Margin="0,0,0,10" Padding="14,10" Click="RequestMoreTime_Click" />
                                    <Button x:Name="ToggleTimerButton" Content="Ocultar/exibir tempo" Padding="14,10" Click="ToggleTimer_Click" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Padding="18"
                    Background="#141D32"
                    BorderBrush="#26314D"
                    BorderThickness="1"
                    CornerRadius="24">
                <StackPanel>
                    <TextBlock Text="Avisos recentes" FontSize="18" FontWeight="SemiBold" />
                    <ListBox x:Name="NotificationsList"
                             Margin="0,12,0,0"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#EEF2FF" />
                </StackPanel>
            </Border>
        </Grid>

        <Border x:Name="SetupOverlay" Background="#D9111720" Visibility="Collapsed">
            <Grid>
                <Border Width="620"
                        MaxHeight="760"
                        Padding="28"
                        Background="#111A2D"
                        BorderBrush="#31405E"
                        BorderThickness="1"
                        CornerRadius="28"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Preparar cliente" FontSize="28" FontWeight="Bold" />
                            <TextBlock Margin="0,10,0,24"
                                       Foreground="#B3C2D9"
                                       Text="Preencha apenas o basico. Depois disso o cliente sincroniza sozinho com o sistema e o tutorial explica o restante."
                                       TextWrapping="Wrap" />

                            <TextBlock Text="Servidor do ADMIN" />
                            <TextBox x:Name="SetupServerUrlTextBox" Margin="0,6,0,14" Padding="10" />
                            <TextBlock Margin="0,-8,0,14"
                                       Foreground="#8FB2D8"
                                       Text="Use o endereco mostrado no app do administrador. Exemplo: http://192.168.0.10:5076/"
                                       TextWrapping="Wrap" />

                            <TextBlock Text="Nome desta maquina" />
                            <TextBox x:Name="SetupMachineNameTextBox" Margin="0,6,0,14" Padding="10" />

                            <TextBlock Text="Chave da maquina" />
                            <TextBox x:Name="SetupMachineKeyTextBox" Margin="0,6,0,14" Padding="10" />

                            <TextBlock Text="Tipo da maquina" />
                            <ComboBox x:Name="SetupMachineKindComboBox" Margin="0,6,0,24" Padding="8" />

                            <Button Content="Salvar e iniciar cliente"
                                    Padding="16,12"
                                    Margin="0,0,0,12"
                                    Click="SaveSetupButton_Click" />
                            <Button Content="Fechar"
                                    Padding="16,12"
                                    Click="CloseSetupButton_Click" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="SettingsOverlay" Background="#D9111720" Visibility="Collapsed">
            <Grid>
                <Border Width="660"
                        MaxHeight="780"
                        Padding="28"
                        Background="#111A2D"
                        BorderBrush="#31405E"
                        BorderThickness="1"
                        CornerRadius="28"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Configuracoes da maquina" FontSize="28" FontWeight="Bold" />
                            <TextBlock Margin="0,10,0,24"
                                       Foreground="#B3C2D9"
                                       Text="Essas configuracoes ficam salvas no proprio cliente para facilitar o uso no dia a dia."
                                       TextWrapping="Wrap" />

                            <TextBlock Text="Servidor do ADMIN" />
                            <TextBox x:Name="SettingsServerUrlTextBox" Margin="0,6,0,14" Padding="10" />
                            <TextBlock Margin="0,-8,0,14"
                                       Foreground="#8FB2D8"
                                       Text="Esse endereco deve apontar para o IP do computador do administrador."
                                       TextWrapping="Wrap" />

                            <TextBlock Text="Nome desta maquina" />
                            <TextBox x:Name="SettingsMachineNameTextBox" Margin="0,6,0,14" Padding="10" />

                            <TextBlock Text="Chave da maquina" />
                            <TextBox x:Name="SettingsMachineKeyTextBox" Margin="0,6,0,14" Padding="10" />

                            <TextBlock Text="Tipo da maquina" />
                            <ComboBox x:Name="SettingsMachineKindComboBox" Margin="0,6,0,14" Padding="8" />

                            <TextBlock Text="Intervalo de sincronizacao (segundos)" />
                            <TextBox x:Name="SettingsSyncIntervalTextBox" Margin="0,6,0,18" Padding="10" />

                            <CheckBox x:Name="RepeatTutorialCheckBox"
                                      Margin="0,0,0,24"
                                      Content="Mostrar o tutorial novamente na proxima abertura" />

                            <WrapPanel>
                                <Button Content="Salvar configuracoes"
                                        Margin="0,0,10,10"
                                        Padding="16,12"
                                        Click="SaveSettingsButton_Click" />
                                <Button Content="Abrir tutorial agora"
                                        Margin="0,0,10,10"
                                        Padding="16,12"
                                        Click="OpenTutorialFromSettingsButton_Click" />
                                <Button Content="Fechar"
                                        Margin="0,0,0,10"
                                        Padding="16,12"
                                        Click="CloseSettingsButton_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="TutorialOverlay" Background="#D9111720" Visibility="Collapsed">
            <Grid>
                <Border Width="720"
                        MaxHeight="780"
                        Padding="28"
                        Background="#111A2D"
                        BorderBrush="#31405E"
                        BorderThickness="1"
                        CornerRadius="28"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Tutorial do cliente" FontSize="28" FontWeight="Bold" />
                            <TextBlock Margin="0,10,0,24"
                                       Foreground="#B3C2D9"
                                       Text="Esse resumo aparece no primeiro uso e pode ser aberto novamente em Configuracoes."
                                       TextWrapping="Wrap" />

                            <Border Margin="0,0,0,12" Padding="18" Background="#18233B" CornerRadius="18" BorderBrush="#2F3D5C" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="1. Entrar" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#B3C2D9" Text="Para liberar a maquina, basta preencher usuario e PIN e tocar em Entrar." TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,0,12" Padding="18" Background="#18233B" CornerRadius="18" BorderBrush="#2F3D5C" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="2. Pedir ajuda" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#B3C2D9" Text="Se precisar de cadastro ou mais tempo, abra Outras opcoes e envie a solicitacao." TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,0,12" Padding="18" Background="#18233B" CornerRadius="18" BorderBrush="#2F3D5C" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="3. Informacoes da sessao" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#B3C2D9" Text="A tela principal mostra tempo, saldo, anotacoes e avisos recentes sem exigir passos extras." TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,0,24" Padding="18" Background="#18233B" CornerRadius="18" BorderBrush="#2F3D5C" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="4. Reabrir este tutorial" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#B3C2D9" Text="O botao Configuracoes permite salvar os dados da maquina e marcar para exibir este tutorial novamente quando quiser." TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Button Content="Concluir" Padding="16,12" Click="CloseTutorialButton_Click" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
