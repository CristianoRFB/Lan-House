<Window x:Class="Adrenalina.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adrenalina Client"
        Width="1280"
        Height="820"
        WindowStartupLocation="CenterScreen"
        Background="#0B1020"
        Foreground="#EEF2FF">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#09111E" Offset="0" />
                <GradientStop Color="#131D33" Offset="0.52" />
                <GradientStop Color="#0D1424" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock x:Name="MachineTitleText" FontSize="28" FontWeight="Bold" Text="ADRENALINA CLIENT" />
                <TextBlock x:Name="SessionStatusText" Margin="0,8,0,0" Foreground="#B3C2D9" Text="Carregando estado local..." />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,24,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="SessionCard"
                        Padding="22"
                        Margin="0,0,14,0"
                        Background="#141D32"
                        BorderBrush="#26314D"
                        BorderThickness="1"
                        CornerRadius="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Sessão atual" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock x:Name="CurrentUserText" Grid.Row="1" Margin="0,16,0,0" FontSize="18" Text="Usuário: aguardando login" />
                        <TextBlock x:Name="ProfileText" Grid.Row="2" Margin="0,6,0,0" Foreground="#B3C2D9" Text="Perfil: bloqueado" />

                        <WrapPanel Grid.Row="3" Margin="0,20,0,0">
                            <Border Padding="16" Margin="0,0,12,0" CornerRadius="18" Background="#1D2944">
                                <StackPanel>
                                    <TextBlock Text="Tempo" Foreground="#B3C2D9" />
                                    <TextBlock x:Name="RemainingTimeText" FontSize="24" FontWeight="Bold" Text="--" />
                                </StackPanel>
                            </Border>
                            <Border Padding="16" Margin="0,0,12,0" CornerRadius="18" Background="#1D2944">
                                <StackPanel>
                                    <TextBlock Text="Saldo" Foreground="#B3C2D9" />
                                    <TextBlock x:Name="BalanceText" FontSize="24" FontWeight="Bold" Text="R$ 0,00" />
                                </StackPanel>
                            </Border>
                            <Border Padding="16" CornerRadius="18" Background="#1D2944">
                                <StackPanel>
                                    <TextBlock Text="Anotado" Foreground="#B3C2D9" />
                                    <TextBlock x:Name="AnnotationText" FontSize="24" FontWeight="Bold" Text="R$ 0,00" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <Border Grid.Row="4"
                                Margin="0,24,0,0"
                                Padding="18"
                                CornerRadius="18"
                                Background="#1A2338"
                                BorderBrush="#2B3652"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Observações da conta" FontWeight="SemiBold" />
                                <TextBlock x:Name="NotesText" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#B3C2D9" Text="Sem observações." />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="LoginCard"
                        Grid.Column="1"
                        Padding="22"
                        Background="#141D32"
                        BorderBrush="#26314D"
                        BorderThickness="1"
                        CornerRadius="24">
                    <StackPanel>
                        <TextBlock Text="Acesso da máquina" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,18" Foreground="#B3C2D9" Text="A máquina permanece travada até o login ser validado." TextWrapping="Wrap" />

                        <TextBlock Text="Usuário" />
                        <TextBox x:Name="LoginTextBox" Margin="0,6,0,12" Padding="10" />

                        <TextBlock Text="PIN de 4 dígitos" />
                        <PasswordBox x:Name="PinBox" Margin="0,6,0,12" Padding="10" />

                        <TextBlock Text="Nome para cadastro" />
                        <TextBox x:Name="DisplayNameTextBox" Margin="0,6,0,12" Padding="10" />

                        <TextBlock Text="Mensagem adicional" />
                        <TextBox x:Name="MessageTextBox" Margin="0,6,0,18" Height="88" Padding="10" TextWrapping="Wrap" AcceptsReturn="True" />

                        <Button x:Name="LoginButton" Content="Entrar" Margin="0,0,0,10" Padding="14,10" Click="LoginButton_Click" />
                        <Button Content="Solicitar cadastro" Margin="0,0,0,10" Padding="14,10" Click="RequestRegistration_Click" />
                        <Button Content="Pedir mais tempo" Margin="0,0,0,10" Padding="14,10" Click="RequestMoreTime_Click" />
                        <Button x:Name="ToggleTimerButton" Content="Ocultar/exibir tempo" Padding="14,10" Click="ToggleTimer_Click" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Padding="18"
                    Background="#141D32"
                    BorderBrush="#26314D"
                    BorderThickness="1"
                    CornerRadius="24">
                <StackPanel>
                    <TextBlock Text="Avisos recentes" FontSize="18" FontWeight="SemiBold" />
                    <ListBox x:Name="NotificationsList"
                             Margin="0,12,0,0"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#EEF2FF" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
